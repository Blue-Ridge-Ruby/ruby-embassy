<% content_for(:title, "#{@hack_project.title} · Hack Day") %>

<section class="pb-32">
  <div class="max-w-3xl mx-auto px-8">
    <% if flash[:notice] %>
      <div class="alert alert-success mb-4"><%= flash[:notice] %></div>
    <% end %>
    <% if flash[:alert] %>
      <div class="alert alert-error mb-4"><%= flash[:alert] %></div>
    <% end %>

    <p class="text-sm text-gray mb-2">
      <%= link_to "← Back to projects", schedule_item_hack_projects_path(@schedule_item), class: "text-blue underline" %>
    </p>

    <div class="flex justify-between items-start mb-2" style="gap: 1rem;">
      <h1 class="text-2xl sm:text-3xl md:text-hero leading-tight font-medium text-navy">
        <%= @hack_project.title %>
      </h1>
      <% if @hack_project.skill_level.present? %>
        <span class="item-badge item-badge--<%= @hack_project.skill_level %>">
          <%= @hack_project.skill_level.titleize %>
        </span>
      <% end %>
    </div>

    <p class="text-sm text-gray mb-4">
      Hosted by <strong><%= @hack_project.host.full_name %></strong>
    </p>

    <% if @hack_project.description.present? %>
      <div class="text-navy mb-6"><%= simple_format(@hack_project.description) %></div>
    <% end %>

    <p class="mb-6">
      <%= link_to "Repository →", @hack_project.repo_url, target: "_blank", rel: "noopener",
                  class: "text-blue underline" %>
      <% if @hack_project.contributors_guide_url.present? %>
        &nbsp;·&nbsp;
        <%= link_to "Contributors guide →", @hack_project.contributors_guide_url,
                    target: "_blank", rel: "noopener", class: "text-blue underline" %>
      <% end %>
    </p>

    <div class="card card-compact mb-6">
      <%= render "signup_button",
                 hack_project:        @hack_project,
                 current_user_signup: @current_user_signup %>
    </div>

    <div class="grid gap-6" style="grid-template-columns: 1fr 1fr;">
      <div>
        <h2 class="text-lg font-medium text-navy mb-2">
          Mentors (<%= @hack_project.mentor_signups.size %>)
        </h2>
        <ul class="space-y-1">
          <% @hack_project.mentor_signups.includes(:user).each do |signup| %>
            <li class="text-navy"><%= signup.user.full_name %></li>
          <% end %>
          <% if @hack_project.mentor_signups.empty? %>
            <li class="text-sm text-gray">No mentors yet.</li>
          <% end %>
        </ul>
      </div>

      <div>
        <h2 class="text-lg font-medium text-navy mb-2">
          Mentees (<%= @hack_project.mentee_signups.size %>)
        </h2>
        <ul class="space-y-1">
          <% @hack_project.mentee_signups.includes(:user).each do |signup| %>
            <li class="text-navy"><%= signup.user.full_name %></li>
          <% end %>
          <% if @hack_project.mentee_signups.empty? %>
            <li class="text-sm text-gray">No mentees yet.</li>
          <% end %>
        </ul>
      </div>
    </div>

    <% if @hack_project.editable_by?(current_user) %>
      <div class="text-center mt-8">
        <%= link_to "Edit project",
                    edit_schedule_item_hack_project_path(@schedule_item, @hack_project),
                    class: "btn btn-muted" %>

        <% if @hack_project.removable_by?(current_user) %>
          <%= button_to "Delete (admin)",
                        admin_hack_project_path(@hack_project),
                        method: :delete,
                        class: "btn btn-muted",
                        data: { turbo_confirm: "Permanently delete #{@hack_project.title}?" } %>
        <% end %>
      </div>
    <% end %>
  </div>
</section>
