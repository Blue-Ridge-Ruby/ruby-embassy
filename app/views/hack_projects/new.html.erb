<% content_for(:title, "Propose a project · #{@schedule_item.title}") %>

<section class="pb-32">
  <div class="max-w-2xl mx-auto px-8">
    <p class="text-sm text-gray mb-2">
      <%= link_to "← Back to projects", schedule_item_hack_projects_path(@schedule_item), class: "text-blue underline" %>
    </p>

    <h1 class="text-2xl sm:text-3xl md:text-hero leading-tight font-medium text-center text-navy mb-4">
      Propose a project
    </h1>

    <p class="plan-intro">
      Bring an open-source project for folks to hack on during Hack Day.
    </p>

    <%= render "form",
               hack_project:      @hack_project,
               form_url:          schedule_item_hack_projects_path(@schedule_item),
               form_method:       :post,
               include_host_role: true,
               submit_label:      "Add this project" %>
  </div>
</section>
