<% content_for(:title, "Schedule · Ruby Embassy") %>

<section class="pb-32">
  <div class="max-w-5xl mx-auto px-8">
    <h1 class="text-2xl sm:text-3xl md:text-hero leading-tight font-medium text-center text-navy mb-4">
      Schedule
    </h1>

    <p class="text-lg leading-relaxed text-gray text-center max-w-2xl mx-auto mb-8">
      Browse the full conference agenda. Tap <span class="font-medium">Add to plan</span> on any talk or <span class="font-medium">RSVP</span> on any activity to save it to your Plan.
    </p>

    <%= render "shared/kind_filter", base_path: schedule_path, selected_kind: @selected_kind %>

    <nav class="kind-filter" aria-label="View options">
      <%= link_to (@show_unplanned ? "✨ Showing new events ✓" : "✨ See new events"),
            schedule_path(request.query_parameters.merge(unplanned: @show_unplanned ? nil : "1").compact),
            class: "kind-filter__btn kind-filter__btn--new-events #{'kind-filter__btn--active' if @show_unplanned}" %>

      <%= link_to (@show_past ? "Hide past events" : "Show past events"),
            schedule_path(request.query_parameters.merge(show_past: @show_past ? nil : "1").compact),
            class: "kind-filter__btn #{'kind-filter__btn--active' if @show_past}" %>
    </nav>

    <% if @items_by_day.empty? %>
      <p class="text-center text-gray py-12">
        No items match this filter.
        <%= link_to "Clear filter", schedule_path, class: "text-blue underline" %>
      </p>
    <% else %>
      <nav class="day-nav" aria-label="Jump to day">
        <% ScheduleItem::DAY_META.each do |day_key, meta| %>
          <% next unless @items_by_day.key?(day_key) %>
          <a href="#<%= day_key %>"><%= meta[:label] %></a>
        <% end %>
      </nav>

      <% ScheduleItem::DAY_META.each do |day_key, meta| %>
        <% items = @items_by_day[day_key] %>
        <% next if items.blank? %>
        <%= render "day", day_key: day_key, meta: meta, items: items, planned_ids: @planned_ids %>
      <% end %>
    <% end %>
  </div>
</section>
