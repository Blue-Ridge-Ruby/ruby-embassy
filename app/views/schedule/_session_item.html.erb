<% if item.lightning? %>
  <%= render "schedule/lightning_session_item", item: item %>
<% else %>
<%
  kind_label = kind_display_label(item.kind)
  flexible_classes = item.flexible? ? "schedule-item--flexible" : ""
  volunteer_classes = item.volunteer_empty? ? "schedule-item--volunteer-empty" : ""

  existing_plan = current_user.plan_items.find_by(schedule_item: item) if planned
  embassy_mode  = item.embassy? ? (item.embassy_mode || "new_passport") : nil

  button_label =
    if planned
      if item.embassy?
        "✓ Booked"
      elsif item.activity?
        "✓ RSVP'd"
      elsif item.volunteer?
        "✓ Volunteering"
      else
        "✓ Added"
      end
    else
      if item.embassy?
        "Schedule Appointment"
      elsif item.activity?
        "+ RSVP"
      elsif item.volunteer?
        "+ Volunteer"
      else
        "+ Add to plan"
      end
    end

  rsvp_note = (item.activity? && item.rsvp_count > 0) ? "#{item.rsvp_count} going" : nil
%>

<%= turbo_frame_tag dom_id(item) do %>
  <article class="schedule-item <%= flexible_classes %> <%= volunteer_classes %>">
    <div class="schedule-item__time">
      <%= item.time_label %>
    </div>

    <div class="schedule-item__content">
      <% if item.talk? && item.host.present? %>
        <h3 class="schedule-item__title"><%= item.title %></h3>
        <p class="schedule-item__host"><%= speaker_link(item) %></p>
      <% else %>
        <h3 class="schedule-item__title"><%= item.title %></h3>
        <% if item.host.present? %>
          <p class="schedule-item__talk-title"><%= item.host %></p>
        <% end %>
      <% end %>

      <% if item.embassy? %>
        <p class="embassy-mode-label"><%= embassy_mode_label(embassy_mode) %></p>
      <% end %>

      <% if item.location.present? %>
        <p class="schedule-item__location"><%= location_or_map_link(item) %></p>
      <% end %>

      <% if item.description.present? %>
        <p class="schedule-item__description"><%= simple_format(item.description, {}, wrapper_tag: "span") %></p>
      <% end %>

      <% if item.meal? %>
        <%= render "schedule/meal_rides_summary", item: item %>
      <% end %>

      <div class="schedule-item__badges">
        <% if kind_label.present? %>
          <span class="item-badge item-badge--<%= item.kind %>"><%= kind_label %></span>
        <% end %>
        <% if item.flexible? %>
          <span class="item-badge item-badge--tbd">TBD</span>
        <% end %>
      </div>

      <% if item.activity? %>
        <%= render "plan_items/attendees", schedule_item: item %>
      <% end %>
    </div>

    <div class="schedule-item__action">
      <% if item.embassy? %>
        <% self_service_available = item.offers_new_passport? || item.offers_stamping? %>
        <% if planned && existing_plan %>
          <%= link_to button_label, plan_path(anchor: dom_id(existing_plan)),
                      class: "add-btn add-btn--added",
                      data: { turbo_frame: "_top" } %>
        <% elsif !self_service_available %>
          <button class="add-btn add-btn--disabled" disabled>By appointment</button>
        <% elsif item.full? %>
          <button class="add-btn add-btn--disabled" disabled>Full</button>
        <% else %>
          <%= link_to button_label,
                      new_embassy_booking_path(schedule_item_id: item.id),
                      class: "add-btn",
                      data: { turbo_frame: "_top" } %>
        <% end %>
        <% if item.total_capacity.positive? %>
          <p class="embassy-capacity">
            <% if item.full? %>
              <%= item.total_capacity %> of <%= item.total_capacity %> · full
            <% else %>
              <%= item.seats_taken %> of <%= item.total_capacity %> seats
            <% end %>
          </p>
        <% end %>
      <% elsif item.volunteer? && !planned && item.volunteer_full? %>
        <button class="add-btn add-btn--disabled" disabled>Filled</button>
      <% elsif planned && existing_plan %>
        <%= link_to button_label, plan_path(anchor: dom_id(existing_plan)),
                    class: "add-btn add-btn--added",
                    data: { turbo_frame: "_top" } %>
      <% else %>
        <%= button_to button_label,
                      plan_items_path,
                      method: :post,
                      params: { schedule_item_id: item.id },
                      class: "add-btn",
                      data: { turbo_frame: dom_id(item) } %>
      <% end %>

      <% if item.volunteer? && item.volunteer_capacity %>
        <% state = item.volunteer_state %>
        <p class="volunteer-capacity volunteer-capacity--<%= state %>">
          <% case state
             when :empty %>
            Help wanted! 0 of <%= item.volunteer_capacity %>
          <% when :partial %>
            <%= item.volunteer_signup_count %> of <%= item.volunteer_capacity %> &mdash; <%= item.volunteer_seats_remaining %> still needed
          <% when :full %>
            Filled (<%= item.volunteer_capacity %> of <%= item.volunteer_capacity %>)
          <% end %>
        </p>
      <% end %>

      <% if rsvp_note %>
        <p class="schedule-item__rsvp-count"><%= rsvp_note %></p>
      <% end %>
    </div>
  </article>
<% end %>
<% end %>
