<% content_for :title, "Hack Day — Admin" %>
<% content_for :container_width, "max-w-6xl" %>

<div class="flex items-center justify-between mb-6 gap-3 flex-wrap">
  <div>
    <h1 class="text-2xl font-bold text-navy">Hack Day</h1>
    <p class="text-muted">
      <%= ScheduleItem::DAY_META.dig(@hack_day.day, :label) %>
      · <%= @hack_day.time_label %>
      · <%= pluralize(@hack_projects.size, "project") %>
    </p>
  </div>
  <%= link_to "+ Add Project", new_admin_hack_project_path, class: "btn btn-red" %>
</div>

<% if @hack_projects.any? %>
  <div class="table-scroll">
    <table class="table">
      <thead>
        <tr>
          <th>Project</th>
          <th>Host</th>
          <th style="width: 110px;">Skill level</th>
          <th style="width: 90px;">Mentors</th>
          <th style="width: 90px;">Mentees</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @hack_projects.each do |project| %>
          <%= render "project_row", project: project %>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="card card-compact text-center">
    <p class="text-lg text-gray mb-2">No projects yet.</p>
    <p class="text-muted text-sm">
      Attendees can propose projects from the Hack Day page,
      or you can add one on their behalf.
    </p>
  </div>
<% end %>
