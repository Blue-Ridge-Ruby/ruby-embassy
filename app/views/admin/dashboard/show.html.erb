<% content_for :container_width, "max-w-6xl" %>

<h1 class="text-2xl font-bold text-navy mb-6">Admin Dashboard</h1>

<h2 class="text-lg font-semibold text-navy mb-4">At a glance</h2>
<div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-10">
  <div class="stat-card">
    <div class="stat-card__label">Attendees</div>
    <div class="stat-card__value"><%= @attendees_count %></div>
    <div class="stat-card__sub">registered</div>
  </div>
  <div class="stat-card">
    <div class="stat-card__label">Embassy Applications</div>
    <div class="stat-card__value"><%= @embassy_applications_count %></div>
    <div class="stat-card__sub">awaiting passport</div>
  </div>
  <div class="stat-card">
    <div class="stat-card__label">RSVPs</div>
    <div class="stat-card__value"><%= @rsvps_count %></div>
    <div class="stat-card__sub">across all items</div>
  </div>
  <div class="stat-card">
    <div class="stat-card__label">Hosted Activities</div>
    <div class="stat-card__value"><%= @hosted_activities_count %></div>
    <div class="stat-card__sub"><%= @public_items_count %> public schedule items</div>
  </div>
</div>

<h2 class="text-lg font-semibold text-navy mb-4">Manage</h2>
<div class="grid grid-cols-2 md:grid-cols-3 gap-3">
  <%= link_to admin_users_path, class: "action-card action-card--compact" do %>
    <div class="action-card__title">Attendees</div>
  <% end %>
  <%= link_to admin_schedule_items_path, class: "action-card action-card--compact" do %>
    <div class="action-card__title">Schedule Items</div>
  <% end %>
  <%= link_to admin_embassy_applications_path, class: "action-card action-card--compact" do %>
    <div class="action-card__title">Embassy Applications</div>
  <% end %>
  <%= link_to admin_embassy_questions_path, class: "action-card action-card--compact" do %>
    <div class="action-card__title">Question Bank</div>
  <% end %>
  <%= link_to new_admin_embassy_blank_pdfs_path, class: "action-card action-card--compact" do %>
    <div class="action-card__title">Generate Blank Forms</div>
  <% end %>
  <%= link_to "/admin/jobs", class: "action-card action-card--compact" do %>
    <div class="action-card__title">Background Jobs</div>
  <% end %>
</div>
