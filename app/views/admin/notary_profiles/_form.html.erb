<%# locals: (notary:) -%>
<% if notary.errors.any? %>
  <div class="alert alert-error mb-4">
    <ul class="list-disc">
      <% notary.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<div class="card card-compact">
  <%= form_with model: notary,
                url: (notary.persisted? ? admin_notary_profile_path(notary) : admin_notary_profiles_path),
                local: true,
                class: "space-y-4" do |f| %>
    <div>
      <%= f.label :external_id, "Notary ID", class: "label" %>
      <%= f.text_field :external_id, class: "input mono",
                       placeholder: "e.g., N37",
                       readonly: notary.persisted? %>
      <p class="text-muted text-sm mt-1">
        Used on printed forms (N01, N02, etc.). Once assigned, do not change.
      </p>
    </div>

    <div>
      <%= f.label :description, "Description (“Someone who…”)", class: "label" %>
      <%= f.text_area :description, rows: 2, class: "input",
                      placeholder: "e.g., Has deployed to production on today's date" %>
    </div>

    <div>
      <%= f.label :followup_prompt, "Follow-up prompt (optional)", class: "label" %>
      <%= f.text_area :followup_prompt, rows: 2, class: "input",
                      placeholder: "e.g., Describe what the notary shipped." %>
      <p class="text-muted text-sm mt-1">
        Shown beneath the description on the printed form. Gives the notary something
        to write.
      </p>
    </div>

    <div>
      <%= f.label :status, class: "label" %>
      <%= f.select :status,
            [["Active", "active"], ["Archived", "archived"]],
            {}, class: "select" %>
    </div>

    <div class="flex gap-3 pt-4">
      <%= f.submit "Save Notary", class: "btn btn-navy" %>
      <%= link_to "Cancel", admin_notary_profiles_path, class: "btn btn-muted" %>
    </div>
  <% end %>
</div>
