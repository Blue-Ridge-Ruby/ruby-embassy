<%# locals: question:, url:, method: :post %>
<div class="card card-compact">
  <%= form_with url: url, method: method, local: true, scope: :question, class: "space-y-4" do |f| %>
    <div>
      <label class="label">Question ID</label>
      <input type="text" name="question[id]" value="<%= question[:id] %>"
             class="input mono" placeholder="e.g., 1a"
             <%= question[:id].present? ? "readonly" : "" %>>
      <p class="text-muted text-sm mt-1">
        Used on printed forms (1a, 1b, 2c, etc.). Once assigned, do not change.
      </p>
    </div>

    <div>
      <label class="label">Section</label>
      <select name="question[section]" class="select">
        <% FakeEmbassy.section_meta.each do |n, meta| %>
          <option value="<%= n %>" <%= "selected" if question[:section] == n %>>
            Section <%= n.to_s.rjust(2, "0") %> · <%= meta[:title] %>
            (<%= meta[:scope] == "random_pool" ? "random pool" : "common" %>)
          </option>
        <% end %>
      </select>
      <p class="text-muted text-sm mt-1">
        Section scope (common vs random pool) is set per section. Questions
        added to a random-pool section become part of that section's draw.
      </p>
    </div>

    <div>
      <label class="label">Question text</label>
      <textarea name="question[label]" rows="2" class="input"><%= question[:label] %></textarea>
    </div>

    <div>
      <label class="label">Type</label>
      <select name="question[type]" class="select">
        <% %i[short long select checkbox date].each do |t| %>
          <option value="<%= t %>" <%= "selected" if question[:type].to_s == t.to_s %>>
            <%= t.to_s.humanize %>
          </option>
        <% end %>
      </select>
    </div>

    <div>
      <label class="label">Help text (optional)</label>
      <input type="text" name="question[help]" value="<%= question[:help] %>"
             class="input"
             placeholder="e.g., Literal or metaphorical answers both accepted.">
    </div>

    <div>
      <label class="label">Options (for select type, one per line)</label>
      <textarea name="question[options]" rows="4" class="input mono"
                placeholder="Yes&#10;No&#10;I plead the fifth"></textarea>
    </div>

    <div class="flex items-center gap-2">
      <input type="checkbox" name="question[required]" value="1"
             <%= "checked" if question[:required] %>>
      <label>Required for adjudication</label>
    </div>

    <div class="flex gap-3 pt-4">
      <button type="submit" class="btn btn-navy">Save Question</button>
      <%= link_to "Cancel", admin_embassy_questions_path, class: "btn btn-muted" %>
    </div>
  <% end %>
</div>
