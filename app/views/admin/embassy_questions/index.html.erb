<% content_for :title, "Question Bank — Embassy Admin" %>

<div class="flex items-center justify-between mb-6 gap-3 flex-wrap">
  <div>
    <h1 class="text-2xl font-bold text-navy">Question Bank</h1>
    <p class="text-muted">
      <%= @questions.count(&:active?) %> active questions ·
      <%= @questions.count { |q| q.random_pool? && q.active? } %> in the random pool (draws <%= EmbassyApplicationDraw::POOL_SIZE %> per application)
    </p>
  </div>
  <%= link_to "+ Add Question", new_admin_embassy_question_path, class: "btn btn-red" %>
</div>

<% [1, 2, 3, 4, 5].each do |number| %>
  <% rows = (@questions_by_section[number] || []).select(&:active?) %>
  <% next if rows.empty? %>

  <% section_meta = EmbassyQuestionsHelper::SECTION_META[number] %>
  <% scope = rows.first.scope %>

  <section class="embassy-bank-section">
    <header class="embassy-bank-section__header">
      <div>
        <h2 class="embassy-bank-section__title">
          Section <%= number.to_s.rjust(2, "0") %>. <%= section_meta[:title] %>
        </h2>
        <p class="embassy-bank-section__hint"><%= section_meta[:instructions] %></p>
      </div>
      <div>
        <% if scope == "random_pool" %>
          <span class="badge-scope badge-scope--random">
            Random pool · draws <%= EmbassyApplicationDraw::POOL_SIZE %> of <%= rows.size %>
          </span>
        <% else %>
          <span class="badge-scope badge-scope--common">
            Common · shown on every application
          </span>
        <% end %>
      </div>
    </header>

    <div class="table-scroll">
    <table class="table">
      <thead>
        <tr>
          <th style="width: 60px;">ID</th>
          <th>Question</th>
          <th style="width: 110px;">Type</th>
          <th style="width: 90px;">Required</th>
          <th style="width: 100px;">Usage</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% rows.each do |q| %>
          <%= render "question_row", question: q %>
        <% end %>
      </tbody>
    </table>
    </div>
  </section>
<% end %>

<% archived = @questions.select(&:archived?) %>
<% if archived.any? %>
  <section class="embassy-bank-section">
    <header class="embassy-bank-section__header">
      <div>
        <h2 class="embassy-bank-section__title">Archived</h2>
        <p class="embassy-bank-section__hint">
          Excluded from new applications. Historical answers still reference these.
        </p>
      </div>
    </header>
    <div class="table-scroll">
    <table class="table">
      <thead>
        <tr>
          <th style="width: 60px;">ID</th>
          <th>Question</th>
          <th style="width: 110px;">Type</th>
          <th style="width: 90px;">Required</th>
          <th style="width: 100px;">Usage</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% archived.each do |q| %>
          <%= render "question_row", question: q %>
        <% end %>
      </tbody>
    </table>
    </div>
  </section>
<% end %>
