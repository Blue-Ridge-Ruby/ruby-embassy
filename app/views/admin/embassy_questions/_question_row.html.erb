<%# locals: (question:) -%>
<tr>
  <td class="mono"><%= question.external_id %></td>
  <td><%= question.label %></td>
  <td><span class="badge badge-<%= question.field_type %>"><%= question.field_type.humanize %></span></td>
  <td><%= question.required? ? "Yes" : "—" %></td>
  <td>
    <span class="mono"><%= question.respond_to?(:computed_usage_count) ? question.computed_usage_count : question.usage_count %></span>
    <span class="text-muted text-sm">uses</span>
  </td>
  <td class="text-right">
    <%= link_to "Edit", edit_admin_embassy_question_path(question),
                class: "text-blue underline" %>
    <% if question.active? %>
      <%= button_to "Archive", admin_embassy_question_path(question),
                    method: :delete,
                    data: { turbo_confirm: "Archive question #{question.external_id}? It will stop appearing in new applications." },
                    class: "btn-ghost ml-2",
                    style: "display:inline;color:#C41C1C;padding:0;box-shadow:none" %>
    <% end %>
  </td>
</tr>
