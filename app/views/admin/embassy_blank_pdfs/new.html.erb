<% content_for :title, "Generate Blank Applications — Embassy Admin" %>

<h1 class="text-2xl font-bold text-navy mb-2">Generate Blank Applications</h1>
<p class="text-muted mb-6">
  Print blank applications for on-site walk-ins. Each blank shows the
  current Section 1, 2, 4, and 5 questions; Section 3 questions and the
  notary assignment are filled in by the Embassy Attaché when an applicant
  picks one up. Submit the form below to download a single PDF containing
  all the blanks you need.
</p>

<div class="card card-compact mb-8">
  <%= form_with url: admin_embassy_blank_pdfs_path, method: :post, data: { turbo: false }, class: "space-y-4" do |f| %>
    <div>
      <label class="label">How many blank applications do you need?</label>
      <input type="number" name="count" value="<%= @default_count %>"
             min="1" max="100" class="input" style="max-width: 160px;">
      <p class="text-muted text-sm mt-1">Minimum 1, maximum 100 per batch.</p>
    </div>

    <div class="flex gap-3 pt-4">
      <button type="submit" class="btn btn-red">Download PDF</button>
      <%= link_to "Cancel", admin_embassy_applications_path, class: "btn btn-muted" %>
    </div>
  <% end %>
</div>
