<% content_for :title, "Submitted Applications — Embassy Admin" %>

<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-navy">Submitted Applications</h1>
    <p class="text-muted">
      <%= @applications.size %> applications &middot; Click a serial to view the full adjudicated form.
    </p>
  </div>
  <%= link_to "Generate Blank Forms",
              new_admin_embassy_blank_pdfs_path,
              class: "btn btn-red" %>
</div>

<% if @applications.empty? %>
  <div class="card text-muted">
    No submitted applications yet. Once attendees submit, they'll appear here.
  </div>
<% else %>
  <table class="table">
    <thead>
      <tr>
        <th style="width: 140px;">Serial</th>
        <th>Attendee</th>
        <th>Appointment</th>
        <th>Submitted</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @applications.each do |application| %>
        <% booking = application.embassy_booking %>
        <% schedule_item = booking.schedule_item %>
        <% user = booking.user %>
        <tr>
          <td class="mono"><%= application.serial %></td>
          <td>
            <div><%= user.full_name %></div>
            <div class="text-muted text-sm"><%= user.email %></div>
          </td>
          <td>
            <%= ScheduleItem::DAY_META.dig(schedule_item.day, :date) %>
            · <%= schedule_item.time_label %>
          </td>
          <td><%= application.submitted_at&.strftime("%b %-d · %-l:%M %p") %></td>
          <td class="text-right">
            <%= link_to "View", admin_embassy_application_path(application),
                        class: "text-blue underline" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>
