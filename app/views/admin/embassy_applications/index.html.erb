<% content_for :title, "Submitted Applications — Embassy Admin" %>

<div class="flex items-center justify-between mb-6 gap-3 flex-wrap">
  <div>
    <h1 class="text-2xl font-bold text-navy">Submitted Applications</h1>
    <p class="text-muted">
      <%= @applications.size %> in queue &middot;
      <%= link_to "See Delivered Passports →", delivered_admin_embassy_applications_path, class: "text-blue underline" %>
    </p>
  </div>
  <%= link_to "Generate Blank Forms",
              new_admin_embassy_blank_pdfs_path,
              class: "btn btn-red" %>
</div>

<%= form_with url: admin_embassy_applications_path, method: :get, local: true, class: "mb-6 flex gap-2 flex-wrap" do %>
  <%= text_field_tag :q, @query,
        placeholder: "Search by name, email, or serial…",
        class: "input flex-1" %>
  <%= hidden_field_tag :sort, @sort %>
  <%= submit_tag "Search", class: "btn btn-navy" %>
  <% if @query.present? %>
    <%= link_to "Clear", admin_embassy_applications_path(sort: @sort), class: "btn btn-ghost" %>
  <% end %>
<% end %>

<% if @applications.empty? %>
  <div class="card text-muted">
    <% if @query.present? %>
      No matches for "<%= @query %>".
    <% else %>
      No submitted applications in the queue. Once attendees submit, they'll appear here.
    <% end %>
  </div>
<% else %>
  <div class="table-scroll">
  <table class="table">
    <thead>
      <tr>
        <th style="width: 140px;"><%= sort_link("Serial", "serial") %></th>
        <th><%= sort_link("Attendee", "name") %></th>
        <th><%= sort_link("Appointment", "appointment") %></th>
        <th>Submitted</th>
        <th>Pickup</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @applications.each do |application| %>
        <% booking = application.embassy_booking %>
        <% schedule_item = booking.schedule_item %>
        <% user = booking.user %>
        <% pickup = @pickups_by_user_id[user.id] %>
        <tr>
          <td class="mono"><%= application.serial %></td>
          <td>
            <div><%= user.full_name %></div>
            <div class="text-muted text-sm"><%= user.email %></div>
          </td>
          <td>
            <%= ScheduleItem::DAY_META.dig(schedule_item.day, :date) %>
            · <%= schedule_item.time_label %>
          </td>
          <td><%= application.submitted_at&.strftime("%b %-d · %-l:%M %p") %></td>
          <td>
            <% if pickup %>
              <%= ScheduleItem::DAY_META.dig(pickup.schedule_item.day, :label) %>
              · <%= pickup.schedule_item.time_label %>
            <% else %>
              <span class="text-muted">—</span>
            <% end %>
          </td>
          <td class="text-right whitespace-nowrap">
            <%= link_to "View", admin_embassy_application_path(application),
                        class: "text-blue underline mr-3" %>
            <%= button_to "Mark Received",
                          mark_received_admin_embassy_application_path(application),
                          method: :patch,
                          class: "btn btn-navy",
                          form: { class: "inline-block" } %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
  </div>
<% end %>
