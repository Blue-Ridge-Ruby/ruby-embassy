<% content_for :title, "Application #{@application.serial} — Embassy Admin" %>

<div class="qa-header">
  <div>
    <h1 class="qa-header__title">
      Application <span class="mono"><%= @application.serial %></span>
    </h1>
    <p class="qa-header__sub">
      <strong><%= @booking.user.full_name %></strong> ·
      <%= ScheduleItem::DAY_META.dig(@schedule_item.day, :date) %> · <%= @schedule_item.time_label %> ·
      submitted <%= @application.submitted_at&.strftime("%b %-d · %-l:%M %p") %>
    </p>
  </div>
  <div class="qa-header__actions">
    <%= link_to "Download PDF", admin_embassy_application_path(@application, format: :pdf), class: "btn btn-red" %>
    <%= link_to "← Back", admin_embassy_applications_path, class: "btn btn-muted" %>
  </div>
</div>

<% if @notary %>
  <%# What notary the applicant must locate, plus the follow-up question they'll be asked. %>
  <div class="qa-strip">
    <div class="qa-strip__cell">
      <span class="qa-strip__label">Notary</span>
      <span class="qa-strip__value">
        <span class="mono"><%= @notary.external_id %></span> ·
        <em>Someone who <%= @notary.description.sub(/^./, &:downcase) %></em>
        <% if @notary.followup_prompt.present? %>
          · follow-up: &ldquo;<%= @notary.followup_prompt %>&rdquo;
        <% end %>
      </span>
    </div>
  </div>
<% end %>

<% [ 1, 2, 3, 4, 5 ].each do |n| %>
  <section class="qa-section <%= "qa-section--pool" if n == 3 %>">
    <h2 class="qa-section__head">
      <span class="qa-section__num">§ <%= n %></span>
      <span class="qa-section__title"><%= embassy_section_title(n) %></span>
      <% if n == 3 %>
        <span class="qa-section__badge">★ Randomized question pool</span>
      <% end %>
    </h2>

    <% @sections[n].each_with_index do |question, idx| %>
      <%= render "question_row",
                 application: @application,
                 question: question,
                 section_label: "#{n}.#{idx + 1}" %>
    <% end %>
  </section>
<% end %>
