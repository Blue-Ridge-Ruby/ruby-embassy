<% if schedule_item.errors.any? %>
  <div class="alert alert-error mb-4">
    <ul class="list-disc">
      <% schedule_item.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<div class="card card-compact">
  <%= form_with model: [ :admin, schedule_item ], class: "space-y-4" do |f| %>
    <div>
      <%= f.label :title, class: "label" %>
      <%= f.text_field :title, required: true, class: "input" %>
    </div>

    <div>
      <%= f.label :kind, class: "label" %>
      <%= f.select :kind,
            ScheduleItem.kinds.keys.map { |k| [ k.humanize, k ] },
            {}, class: "select" %>
    </div>

    <div>
      <%= f.label :day, class: "label" %>
      <%= f.select :day,
            ScheduleItem::DAY_META.map { |k, m| [ m[:label], k ] },
            {}, class: "select" %>
    </div>

    <div>
      <%= f.label :time_label, "Time label", class: "label" %>
      <%= f.text_field :time_label, class: "input", placeholder: "e.g., 9:30 AM, TBD" %>
    </div>

    <div>
      <%= f.label :sort_time, "Sort order", class: "label" %>
      <%= f.number_field :sort_time, class: "input", placeholder: "e.g., 930" %>
    </div>

    <div>
      <%= f.label :host, "Host / speaker", class: "label" %>
      <%
        # Pull every existing user as a host option. Preserve the current
        # host value as a sticky top option if it doesn't match a user —
        # so seeded external speakers (e.g., "John Athayde") aren't lost
        # when an admin edits the talk.
        existing_names = User.order(:last_name, :first_name).map(&:full_name).uniq
        current_host   = schedule_item.host.presence
        sticky_options = current_host && !existing_names.include?(current_host) ? [ current_host ] : []
        all_options    = (sticky_options + existing_names).map { |name| [ name, name ] }
      %>
      <%= f.select :host,
            options_for_select(all_options, current_host),
            { include_blank: "— None —" },
            class: "select" %>
    </div>

    <div>
      <%= f.label :location, class: "label" %>
      <%= f.text_field :location, class: "input" %>
    </div>

    <div>
      <%= f.label :description, class: "label" %>
      <%= f.text_area :description, rows: 3, class: "input" %>
    </div>

    <div class="flex items-center gap-2">
      <%= f.check_box :flexible %>
      <%= f.label :flexible, "Flexible / TBD (Saturday dashed treatment)" %>
    </div>

    <div class="flex items-center gap-2">
      <%= f.check_box :is_public %>
      <%= f.label :is_public, "Public (appears on /schedule for all attendees)" %>
    </div>

    <details class="embassy-form-extras" <%= schedule_item.kind == "embassy" ? "open" : "" %>>
      <summary>
        <strong>Embassy-only settings</strong>
        <span class="text-muted">· expand when Kind = Embassy</span>
      </summary>

      <div class="embassy-form-extras__body">
        <p class="text-muted text-sm mb-3">
          These fields only take effect for items where <strong>Kind = Embassy</strong>.
          Rendered as raw inputs for the mockup &mdash; a backend pass adds
          <code>capacity</code> and <code>embassy_mode</code> columns to
          <code>schedule_items</code>.
        </p>

        <div>
          <label class="label">Capacity (seats per block)</label>
          <input type="number" name="schedule_item[capacity]" value="8"
                 min="1" max="50" class="input" style="max-width: 160px;"
                 placeholder="e.g., 8">
        </div>

        <div class="mt-3">
          <label class="label">Embassy mode</label>
          <select name="schedule_item[embassy_mode]" class="select">
            <option value="new_passport">New passport only (application required)</option>
            <option value="stamping">Stamping only (existing passport)</option>
            <option value="both" selected>New passport or Stamping (user chooses at booking)</option>
          </select>
        </div>
      </div>
    </details>

    <div class="flex gap-3 pt-4">
      <%= f.submit class: "btn btn-navy" %>
      <%= link_to "Cancel", admin_schedule_items_path, class: "btn btn-muted" %>
    </div>
  <% end %>
</div>
