<% if schedule_item.errors.any? %>
  <div class="alert alert-error mb-4">
    <ul class="list-disc">
      <% schedule_item.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%
  raw_return_to = params[:return_to].to_s
  return_to = (raw_return_to.start_with?("/") && !raw_return_to.start_with?("//")) ? raw_return_to : nil
%>

<div class="card card-compact">
  <%= form_with model: [ :admin, schedule_item ],
                class: "space-y-4",
                data: { controller: "embassy-settings" } do |f| %>
    <% if return_to %>
      <%= hidden_field_tag :return_to, return_to %>
    <% end %>

    <div>
      <%= f.label :title, class: "label" %>
      <%= f.text_field :title, required: true, class: "input" %>
    </div>

    <div>
      <%= f.label :kind, class: "label" %>
      <%= f.select :kind,
            ScheduleItem.kinds.keys.map { |k| [ k.humanize, k ] },
            {},
            class: "select",
            data: { embassy_settings_target: "kindSelect", action: "change->embassy-settings#toggle" } %>
    </div>

    <div>
      <%= f.label :day, class: "label" %>
      <%= f.select :day,
            ScheduleItem::DAY_META.map { |k, m| [ m[:label], k ] },
            {}, class: "select" %>
    </div>

    <div>
      <%= f.label :time_label, "Time label", class: "label" %>
      <%= f.text_field :time_label, class: "input", placeholder: "e.g., 9:30 AM, TBD" %>
    </div>

    <div>
      <%= f.label :sort_time, "Sort order", class: "label" %>
      <%= f.number_field :sort_time, class: "input", placeholder: "e.g., 930" %>
    </div>

    <div>
      <%= f.label :host, "Host / speaker", class: "label" %>
      <%
        # Pull every existing user as a host option. Preserve the current
        # host value as a sticky top option if it doesn't match a user —
        # so seeded external speakers (e.g., "John Athayde") aren't lost
        # when an admin edits the talk.
        existing_names = User.all.map(&:full_name).uniq
        current_host   = schedule_item.host.presence
        sticky_options = current_host && !existing_names.include?(current_host) ? [ current_host ] : []
        sorted_names   = (sticky_options + existing_names).sort_by { |name| name.downcase }
        all_options    = sorted_names.map { |name| [ name, name ] }
      %>
      <%= f.select :host,
            options_for_select(all_options, current_host),
            { include_blank: "— None —" },
            class: "select" %>
    </div>

    <div>
      <%= f.label :location, class: "label" %>
      <%= f.text_field :location, class: "input" %>
    </div>

    <div>
      <%= f.label :map_url, "Map URL", class: "label" %>
      <%= f.url_field :map_url, class: "input",
            placeholder: "https://maps.app.goo.gl/..." %>
      <p class="text-muted text-sm mt-1">
        Optional. Paste a Google Maps short URL. If set, the venue name becomes a link on the schedule.
      </p>
    </div>

    <div>
      <%= f.label :description, class: "label" %>
      <%= f.text_area :description, rows: 3, class: "input" %>
    </div>

    <div class="flex items-center gap-2">
      <%= f.check_box :flexible %>
      <%= f.label :flexible, "Flexible / TBD (Saturday dashed treatment)" %>
    </div>

    <div class="flex items-center gap-2">
      <%= f.check_box :is_public %>
      <%= f.label :is_public, "Public (appears on /schedule for all attendees)" %>
    </div>

    <div class="flex items-center gap-2">
      <%= f.check_box :passed %>
      <%= f.label :passed, "Marked passed (hidden from /schedule and /plan unless 'Show past events')" %>
    </div>

    <div>
      <%= f.label :audience, "Visible to", class: "label" %>
      <%= f.select :audience,
            [ [ "Everyone", "everyone" ], [ "Volunteers only", "volunteers_only" ] ],
            {}, class: "select" %>
      <p class="text-muted text-sm mt-1">
        "Volunteers only" hides the event from regular attendees on /schedule.
        Admins always see all public events.
      </p>
    </div>

    <div class="embassy-form-extras"
         data-embassy-settings-target="extras"
         <%= "hidden".html_safe unless schedule_item.kind == "embassy" %>>
      <h3 class="font-bold mb-2">Embassy-only settings</h3>
      <p class="text-muted text-sm mb-3">
        Pick which modes this block accepts, then set capacity for each.
        Passport pickup is admin-scheduled only — attendees won't see it as a booking option.
      </p>

      <fieldset class="space-y-2">
        <legend class="label">Embassy mode</legend>
        <% [ [:new_passport,    "New passport (application required)"],
             [:stamping,        "Stamping (existing passport)"],
             [:passport_pickup, "Passport pickup (admin-scheduled only)"] ].each do |mode, label| %>
          <label class="flex items-center gap-2">
            <%= f.check_box "offers_#{mode}",
                  data: { embassy_settings_target: "#{mode.to_s.camelize(:lower)}Toggle",
                          action: "change->embassy-settings#toggleCapacity" } %>
            <%= label %>
          </label>
        <% end %>
      </fieldset>

      <% [ [:new_passport,    "New passport slots"],
           [:stamping,        "Stamping slots"],
           [:passport_pickup, "Passport pickup slots"] ].each do |mode, label| %>
        <div class="mt-3"
             data-embassy-settings-target="<%= mode.to_s.camelize(:lower) %>Capacity"
             <%= "hidden".html_safe unless schedule_item.public_send("offers_#{mode}") %>>
          <%= f.label "#{mode}_capacity", label, class: "label" %>
          <%= f.number_field "#{mode}_capacity", min: 1, max: 50,
                class: "input", style: "max-width: 160px;", placeholder: "e.g., 3" %>
        </div>
      <% end %>
    </div>

    <div class="volunteer-form-extras"
         data-embassy-settings-target="volunteerExtras"
         <%= "hidden".html_safe unless schedule_item.kind == "volunteer" %>>
      <h3 class="font-bold mb-2">Volunteer-only settings</h3>
      <p class="text-muted text-sm mb-3">
        These fields only apply when <strong>Kind = Volunteer</strong>. Set how
        many people you need to fill this slot — once it hits capacity, signups
        are blocked.
      </p>

      <div>
        <%= f.label :volunteer_capacity, "Volunteers needed", class: "label" %>
        <%= f.number_field :volunteer_capacity, min: 1, max: 50,
              class: "input", style: "max-width: 160px;",
              placeholder: "e.g., 3" %>
      </div>
    </div>

    <div class="flex gap-3 pt-4">
      <%= f.submit class: "btn btn-navy" %>
      <%= link_to "Cancel", return_to || admin_schedule_items_path, class: "btn btn-muted" %>
    </div>
  <% end %>
</div>
