<% if schedule_item.errors.any? %>
  <div class="alert alert-error mb-4">
    <ul class="list-disc">
      <% schedule_item.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<div class="card card-compact">
  <%= form_with model: [ :admin, schedule_item ], class: "space-y-4" do |f| %>
    <div>
      <%= f.label :title, class: "label" %>
      <%= f.text_field :title, required: true, class: "input" %>
    </div>

    <div>
      <%= f.label :kind, class: "label" %>
      <%= f.select :kind,
            ScheduleItem.kinds.keys.map { |k| [ k.humanize, k ] },
            {}, class: "select" %>
    </div>

    <div>
      <%= f.label :day, class: "label" %>
      <%= f.select :day,
            ScheduleItem::DAY_META.map { |k, m| [ m[:label], k ] },
            {}, class: "select" %>
    </div>

    <div>
      <%= f.label :time_label, "Time label", class: "label" %>
      <%= f.text_field :time_label, class: "input", placeholder: "e.g., 9:30 AM, TBD" %>
    </div>

    <div>
      <%= f.label :sort_time, "Sort order", class: "label" %>
      <%= f.number_field :sort_time, class: "input", placeholder: "e.g., 930" %>
    </div>

    <div>
      <%= f.label :host, "Host / speaker", class: "label" %>
      <%= f.text_field :host, class: "input" %>
    </div>

    <div>
      <%= f.label :location, class: "label" %>
      <%= f.text_field :location, class: "input" %>
    </div>

    <div>
      <%= f.label :description, class: "label" %>
      <%= f.text_area :description, rows: 3, class: "input" %>
    </div>

    <div>
      <%= f.label :slug, "Slug (optional)", class: "label" %>
      <%= f.text_field :slug, class: "input", placeholder: "leave blank for admin-created items" %>
    </div>

    <div class="flex items-center gap-2">
      <%= f.check_box :flexible %>
      <%= f.label :flexible, "Flexible / TBD (Saturday dashed treatment)" %>
    </div>

    <div class="flex items-center gap-2">
      <%= f.check_box :is_public %>
      <%= f.label :is_public, "Public (appears on /schedule for all attendees)" %>
    </div>

    <div class="flex gap-3 pt-4">
      <%= f.submit class: "btn btn-navy" %>
      <%= link_to "Cancel", admin_schedule_items_path, class: "btn btn-muted" %>
    </div>
  <% end %>
</div>
