<% content_for :title, (@application.draft? ? "New Passport Application — Ruby Embassy" : "Application — Ruby Embassy") %>

<%
  editing = @application.persisted? && action_name == "edit"
  form_url    = editing ? embassy_application_path(@application) : embassy_applications_path
  form_method = editing ? :patch : :post
%>

<div class="application-canvas">
  <header class="application-canvas__header">
    <div class="embassy-form-code">Form RUBY-1.0-MATZ &middot; Rev. 04/2026</div>

    <h1 class="application-canvas__title">Ruby Embassy</h1>
    <p class="application-canvas__subtitle">Application for Issuance of New Ruby Passport</p>
  </header>

  <section class="card mb-6">
    <%= render "appointment_card",
               application: @application,
               schedule_item: @schedule_item,
               state: "pending" %>
  </section>

  <p class="application-canvas__instructions">
    Fields marked with an asterisk (*) are required for adjudication under
    Embassy Ordinance §1.1. The Embassy reserves the right, in its sole
    discretion, to reject applications deemed insufficiently Ruby.
  </p>

  <% if @application.errors.any? %>
    <div class="alert alert-error mb-4">
      <p><strong>Please answer the following required questions:</strong></p>
      <ul class="list-disc">
        <% @application.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with url: form_url,
                method: form_method,
                local: true,
                class: "application-form" do |f| %>
    <%= hidden_field_tag :embassy_booking_id, @booking.id %>

    <% [1, 2, 3, 4, 5].each do |n| %>
      <%= render "section", number: n, questions: @sections[n], application: @application %>
    <% end %>

    <footer class="application-canvas__footer">
      <div class="application-canvas__serial">
        <span class="embassy-serial mono"><%= @application.serial %></span>
      </div>

      <div class="application-canvas__actions">
        <button type="submit"
                name="intent"
                value="submit"
                class="btn btn-red btn-lg"
                data-turbo-confirm="Submit application? You cannot edit after submission.">
          Submit Application
        </button>
        <button type="submit" name="intent" value="draft" class="btn btn-muted">
          Save &amp; Return Later
        </button>
      </div>

      <p class="application-canvas__footer-note text-muted">
        By submitting, the Applicant affirms that all declarations made above
        are truthful to the best of their Ruby-ly knowledge. Once submitted,
        the application is final and may no longer be edited.
      </p>
    </footer>
  <% end %>
</div>
