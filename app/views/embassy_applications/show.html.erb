<% content_for :title, "Application Submitted — Ruby Embassy" %>

<div class="embassy-doc">
  <header class="embassy-doc__header">
    <p class="embassy-form-code">Form RUBY-1.0-MATZ · Rev. 04/2026</p>
    <h1 class="embassy-doc__title">Application Received</h1>
    <p class="embassy-doc__subtitle">The Applicant's appointment is confirmed. Please print and bring the attached application to the Embassy.</p>
  </header>

  <div class="embassy-ceremony">
    <%= render "appointment_card",
               application: @application,
               schedule_item: @schedule_item,
               state: "submitted" %>

    <section class="embassy-ceremony__callout">
      <p class="embassy-ceremony__serial-label">OFFICIAL SERIAL</p>
      <p class="embassy-ceremony__serial-value mono"><%= @application.serial %></p>
      <p class="embassy-ceremony__serial-note">
        Retain this serial on the printed application. The Embassy Attaché
        shall reference it to locate the Applicant's record upon arrival.
      </p>
    </section>

    <section class="embassy-ceremony__download">
      <%= link_to "Download & Print Application (PDF)",
                  embassy_application_path(@application, format: :pdf),
                  class: "btn btn-red btn-lg" %>
      <p class="text-muted mt-2">
        3 pages · standard letter size · includes Notary Certification
      </p>
    </section>

    <section class="embassy-ceremony__etiquette">
      <h2 class="embassy-section-header">Embassy Hours &amp; Protocol</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="card card-compact">
          <h3 class="embassy-section-subhead">Hours of operation</h3>
          <ul class="list-disc">
            <% embassy_hours.each do |h| %>
              <li><%= h %></li>
            <% end %>
          </ul>
        </div>
        <div class="card card-compact">
          <h3 class="embassy-section-subhead">Standing protocol</h3>
          <ul class="list-disc">
            <% embassy_etiquette.each do |note| %>
              <li><%= note %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </section>

    <section class="embassy-ceremony__back">
      <%= link_to "← View My Plan", plan_path, class: "btn btn-navy" %>
      <%= link_to "Back to Schedule", schedule_path, class: "btn btn-muted" %>
    </section>
  </div>
</div>
