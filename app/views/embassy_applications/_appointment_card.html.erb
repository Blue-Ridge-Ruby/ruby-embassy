<%# locals: (application:, schedule_item:, state: "default") -%>
<article class="embassy-appointment-card embassy-appointment-card--<%= state %>">
  <div class="embassy-appointment-card__serial mono"><%= application.serial %></div>

  <p class="embassy-appointment-card__eyebrow">Ruby Embassy Appointment</p>

  <h3 class="embassy-appointment-card__when">
    <%= ScheduleItem::DAY_META.dig(schedule_item.day, :label) %>
    <span class="embassy-appointment-card__dot">·</span>
    <%= schedule_item.time_label %>
  </h3>

  <p class="embassy-appointment-card__where">
    <%= schedule_item.location.presence || "Embassy Office · Main Hall" %>
  </p>

  <dl class="embassy-appointment-card__dl">
    <dt>Classification</dt>
    <dd><%= embassy_mode_label(application.embassy_booking.mode) %></dd>

    <dt>Applicant</dt>
    <dd><%= application.user.full_name %></dd>
  </dl>
</article>
