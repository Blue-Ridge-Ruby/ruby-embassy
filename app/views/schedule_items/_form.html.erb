<%= form_with model: schedule_item, local: true do |f| %>
  <% if schedule_item.errors.any? %>
    <div class="form-errors">
      <h3><%= pluralize(schedule_item.errors.count, "error") %> prevented saving:</h3>
      <ul>
        <% schedule_item.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-row">
    <%= f.label :title %>
    <%= f.text_field :title, required: true %>
  </div>

  <div class="form-row">
    <%= f.label :day %>
    <%= f.select :day, ScheduleItem::DAY_META.map { |k, m| [ m[:label], k ] } %>
  </div>

  <div class="form-row">
    <%= f.label :time_label, "Time (display label, e.g., '6:30 PM')" %>
    <%= f.text_field :time_label %>
  </div>

  <div class="form-row">
    <%= f.label :sort_time, "Sort time (integer, e.g., 1830 for 6:30 PM)" %>
    <%= f.number_field :sort_time %>
  </div>

  <div class="form-row">
    <%= f.label :host, "Host (optional)" %>
    <%= f.text_field :host %>
  </div>

  <div class="form-row">
    <%= f.label :location, "Location (optional)" %>
    <%= f.text_field :location %>
  </div>

  <div class="form-row">
    <%= f.label :description, "Description (optional)" %>
    <%= f.text_area :description, rows: 3 %>
  </div>

  <div class="form-row">
    <%= f.check_box :is_public %>
    <%= f.label :is_public, "Share with all attendees — they can RSVP" %>
  </div>

  <div class="form-actions">
    <%= f.submit %>
    <%= link_to "Cancel", plan_path %>
  </div>
<% end %>
