<%
  item       = plan_item.schedule_item
  custom     = item.created_by_id == current_user.id
  presenting = item.lightning? && @speaking_ids&.include?(item.id)
  custom_class = custom ? "plan-item--custom" : ""
%>

<%= turbo_frame_tag dom_id(plan_item) do %>
  <% if item.embassy? %>
    <%
      booking     = current_user.embassy_bookings.find_by(schedule_item: item)
      application = booking&.embassy_application
      mode        = booking&.mode || "new_passport"
      state       =
        if booking.nil? then "stamping"
        elsif booking.stamping? then "stamping"
        elsif application&.submitted? then "submitted"
        else "pending"
        end
    %>
    <article class="plan-item plan-item--embassy plan-item--embassy-<%= state %>">
      <div class="plan-item__embassy-body">
        <div class="embassy-appointment-card embassy-appointment-card--<%= state %>">
          <% if application&.serial %>
            <div class="embassy-appointment-card__serial mono"><%= application.serial %></div>
          <% end %>
          <p class="embassy-appointment-card__eyebrow">Ruby Embassy Appointment</p>
          <h3 class="embassy-appointment-card__when">
            <%= ScheduleItem::DAY_META.dig(item.day, :label) %>
            <span class="embassy-appointment-card__dot">·</span>
            <%= item.time_label %>
          </h3>
          <p class="embassy-appointment-card__where">
            <%= item.location.presence || "Embassy Office · Main Hall" %>
          </p>
          <dl class="embassy-appointment-card__dl">
            <dt>Classification</dt>
            <dd><%= embassy_mode_label(mode) %></dd>
            <dt>Applicant</dt>
            <dd><%= current_user.full_name %></dd>
          </dl>
        </div>

        <div class="plan-item__embassy-action">
          <% case state %>
          <% when "stamping" %>
            <p class="plan-item__embassy-note">
              <strong>Stamping appointment.</strong>
              Present existing Ruby Embassy Passport at the Embassy Office at the time above.
            </p>

          <% when "pending" %>
            <p class="plan-item__embassy-note">
              Application in progress.
            </p>
            <%= link_to "Continue Application",
                        edit_embassy_application_path(application),
                        class: "btn btn-red",
                        data: { turbo_frame: "_top" } %>

          <% when "submitted" %>
            <p class="plan-item__embassy-note">
              Application filed · Serial <span class="mono"><%= application.serial %></span>
            </p>
            <%= link_to "View / Download PDF",
                        embassy_application_path(application),
                        class: "btn btn-navy",
                        data: { turbo_frame: "_top" } %>
          <% end %>
        </div>
      </div>

      <% unless state == "submitted" %>
        <%= button_to "×",
                      plan_item_path(plan_item),
                      method: :delete,
                      class: "plan-item__remove",
                      aria: { label: "Cancel appointment" },
                      data: { turbo_confirm: "Cancel your Embassy appointment?" } %>
      <% end %>
    </article>

  <% else %>
    <article class="plan-item <%= custom_class %>">
      <div class="plan-item__time"><%= item.time_label %></div>

      <div class="plan-item__content">
        <% if item.talk? && item.host.present? %>
          <h3 class="plan-item__title"><%= item.host %></h3>
          <p class="plan-item__talk-title">&ldquo;<%= item.title %>&rdquo;</p>
        <% else %>
          <h3 class="plan-item__title"><%= item.title %></h3>
          <% if item.host.present? %>
            <p class="plan-item__talk-title"><%= item.host %></p>
          <% end %>
        <% end %>

        <% if item.location.present? %>
          <p class="plan-item__location"><%= location_or_map_link(item) %></p>
        <% end %>

        <% if item.meal? %>
          <%= render "plan/meal_spot_block", item: item %>
        <% end %>

        <% if item.description.present? %>
          <p class="plan-item__description"><%= simple_format(item.description, {}, wrapper_tag: "span") %></p>
        <% end %>

        <div class="schedule-item__badges">
          <% if item.kind.present? %>
            <span class="item-badge item-badge--<%= item.kind %>"><%= item.kind.humanize %></span>
          <% end %>
          <span class="item-badge item-badge--<%= item.is_public? ? "public" : "private" %>">
            <%= item.is_public? ? "Public" : "Private" %>
          </span>
          <% if presenting %>
            <span class="item-badge item-badge--presenting">Presenting</span>
          <% end %>
          <% if custom %>
            <span class="item-badge item-badge--custom">Custom</span>
          <% end %>
        </div>

        <% if presenting %>
          <p class="plan-item__notes">
            <%= link_to "Edit my lightning talk",
                        edit_schedule_item_lightning_talk_signup_path(item),
                        data: { turbo_frame: "_top" } %>
          </p>
        <% end %>

        <% if plan_item.notes.present? %>
          <p class="plan-item__notes"><%= plan_item.notes %></p>
        <% end %>
      </div>

      <% unless presenting %>
        <%= button_to "×",
                      plan_item_path(plan_item),
                      method: :delete,
                      class: "plan-item__remove",
                      aria: { label: "Remove from plan" },
                      data: { turbo_confirm: "Remove '#{item.title}' from your plan?" } %>
      <% end %>
    </article>
  <% end %>
<% end %>
