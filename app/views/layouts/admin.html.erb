<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "Admin — Ruby Embassy" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/favicon.ico" sizes="any">

    <link rel="stylesheet" href="https://use.typekit.net/bzt5uqd.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-50">
    <div data-controller="toggle" data-toggle-toggle-class="hidden">
      <nav class="admin-nav">
        <%= link_to "Ruby Embassy Admin", admin_root_path, class: "font-semibold" %>
        <%= link_to "Admin Dashboard", admin_root_path %>
        <%= link_to "Attendees", admin_users_path %>
        <%= link_to "Volunteers", admin_volunteers_path %>
        <%= link_to "Schedule", admin_schedule_items_path %>
        <%= link_to "Embassy Applications", admin_embassy_applications_path %>
        <span class="ml-auto flex items-center gap-4">
          <%= link_to "Back to User Dashboard", dashboard_path %>
          <%= button_to "Sign out", session_path, method: :delete, class: "admin-nav-btn" %>
        </span>

        <button data-action="click->toggle#toggle click@window->toggle#hide" class="admin-nav__burger" aria-label="Open menu">
          <span class="sr-only">Open main menu</span>
          <svg class="block h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </nav>

      <div data-toggle-target="toggleable" class="admin-nav__drawer hidden">
        <%= link_to "Admin Dashboard", admin_root_path %>
        <%= link_to "Attendees", admin_users_path %>
        <%= link_to "Volunteers", admin_volunteers_path %>
        <%= link_to "Schedule", admin_schedule_items_path %>
        <%= link_to "Embassy Applications", admin_embassy_applications_path %>
        <%= link_to "Back to User Dashboard", dashboard_path %>
        <div>
          <%= button_to "Sign out", session_path, method: :delete, class: "admin-nav-btn" %>
        </div>
      </div>
    </div>

    <main class="px-8 py-10">
      <div class="<%= content_for?(:container_width) ? yield(:container_width) : 'max-w-4xl' %> mx-auto">
        <% if flash[:notice] %>
          <div class="alert alert-notice"><%= flash[:notice] %></div>
        <% end %>
        <% if flash[:alert] %>
          <div class="alert alert-error"><%= flash[:alert] %></div>
        <% end %>

        <%= yield %>
      </div>
    </main>
  </body>
</html>
