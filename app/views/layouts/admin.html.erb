<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Admin — Ruby Embassy" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-50">
    <nav class="bg-gray-900 text-white px-6 py-3 flex items-center gap-6">
      <span class="font-bold">Ruby Embassy — Admin</span>
      <%= link_to "Users", admin_users_path, class: "hover:underline" %>
      <%= link_to "Configurations", admin_configurations_path, class: "hover:underline" %>
      <%= link_to "Jobs", "/admin/jobs", class: "hover:underline" %>
      <span class="ml-auto flex items-center gap-4">
        <%= link_to "Dashboard", dashboard_path, class: "hover:underline" %>
        <%= button_to "Sign out", session_path, method: :delete,
              class: "bg-gray-700 text-white py-1 px-3 rounded hover:bg-gray-600 cursor-pointer" %>
      </span>
    </nav>

    <main class="px-6 py-8">
      <% if flash[:notice] %>
        <div class="max-w-4xl mx-auto mb-4 p-3 rounded bg-green-100 text-green-800"><%= flash[:notice] %></div>
      <% end %>
      <% if flash[:alert] %>
        <div class="max-w-4xl mx-auto mb-4 p-3 rounded bg-red-100 text-red-800"><%= flash[:alert] %></div>
      <% end %>

      <div class="max-w-4xl mx-auto">
        <%= yield %>
      </div>
    </main>
  </body>
</html>
