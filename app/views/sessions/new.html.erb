<div class="max-w-sm mx-auto py-16">
  <h1 class="text-2xl font-bold mb-2 text-center">Sign In</h1>
  <p class="text-gray-600 text-center mb-8">Enter your email and we'll send you a login link.</p>

  <% if flash[:notice] %>
    <div class="mb-4 p-3 rounded bg-green-100 text-green-800 text-center"><%= flash[:notice] %></div>
  <% end %>
  <% if flash[:alert] %>
    <div class="mb-4 p-3 rounded bg-red-100 text-red-800 text-center"><%= flash[:alert] %></div>
  <% end %>

  <%= form_with url: session_path, method: :post, class: "space-y-4" do |f| %>
    <fieldset>
      <legend class="block text-sm font-medium mb-1">Email address</legend>
      <%= f.email_field :email, required: true, autofocus: true,
            value: params[:email],
            class: "w-full border rounded px-3 py-2" %>
    </fieldset>

    <%= f.submit "Send login link",
          class: "w-full bg-[#C0392B] text-white py-2 px-4 rounded font-medium hover:bg-[#a5321f] cursor-pointer" %>
  <% end %>

  <p class="text-sm text-gray-600 text-center mt-6">
    Don't have a ticket yet?
    <%= link_to "Register for Blue Ridge Ruby", "https://blueridgeruby.com/#register",
          class: "text-[#C0392B] hover:underline" %>
  </p>
</div>
