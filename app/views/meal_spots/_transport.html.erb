<%
  user_on_this_transport = current_user_rsvp&.meal_spot_transport_id == transport.id
  user_has_other_rsvp    = current_user_rsvp.present? && !user_on_this_transport
  rsvps                  = transport.rsvps.includes(:user).to_a
  contacts_visible       = spot.created_by_id == current_user.id ||
                           rsvps.any? { |r| r.user_id == current_user.id }
  depart_label = transport.departs_at.strftime("%-l:%M %p")
  mode_label   = transport.mode_label.downcase

  button_label =
    if user_on_this_transport
      "✓ You're #{mode_label}"
    elsif transport.full?
      "Full"
    elsif user_has_other_rsvp
      "Switch to #{mode_label} (#{depart_label})"
    else
      "I'm in (#{mode_label}, #{depart_label})"
    end
%>

<div class="flex items-start" style="justify-content: space-between; gap: 1rem; padding: 0.75rem; background: #f9fafb; border-radius: 8px;">
  <div style="flex: 1;">
    <p class="text-navy" style="font-weight: 500;">
      <%= transport.mode_label %> · leaves <%= depart_label %>
      <% if transport.driving? %>
        · <span class="text-sm text-gray">
          <% if transport.full? %>
            <%= transport.seats_offered %> of <%= transport.seats_offered %> passenger seats · full
          <% else %>
            <%= transport.passenger_count %> of <%= transport.seats_offered %> passenger seats
          <% end %>
        </span>
      <% end %>
    </p>
    <% if rsvps.any? %>
      <ul style="margin-top: 0.25rem; list-style: none; padding-left: 0;">
        <% rsvps.each do |rsvp| %>
          <%= render "meal_spot_rsvps/attendee_row",
                     rsvp:             rsvp,
                     meal:             meal,
                     spot:             spot,
                     contacts_visible: contacts_visible %>
        <% end %>
      </ul>
    <% else %>
      <p class="text-sm text-gray">Nobody yet</p>
    <% end %>
    <% if transport.meet_up_spot.present? %>
      <p class="text-sm text-gray">Meet at <%= transport.meet_up_spot %></p>
    <% end %>
  </div>

  <% if user_on_this_transport && current_user_rsvp %>
    <% if current_user_rsvp.locked_in? %>
      <button class="add-btn add-btn--added" disabled aria-pressed="true"
              title="<%= current_user_rsvp.lock_reason %>">
        <%= button_label %>
      </button>
    <% else %>
      <%= button_to button_label,
                    schedule_item_meal_spot_rsvp_path(meal, spot, current_user_rsvp),
                    method: :delete,
                    class: "add-btn add-btn--added" %>
    <% end %>
  <% elsif current_user_rsvp&.locked_in? %>
    <%# User is locked to their current transport — no switch affordance %>
  <% elsif transport.full? %>
    <button class="add-btn add-btn--disabled" disabled><%= button_label %></button>
  <% else %>
    <%= button_to button_label,
                  schedule_item_meal_spot_rsvps_path(meal, spot, transport_id: transport.id),
                  method: :post,
                  class: "add-btn" %>
  <% end %>
</div>
